{
    "name": "bolt-php/validation",
    "type": "library",
    "keywords": [
        "php",
        "validation"
    ],
    "description": "Validator package for Tiny PHP",
    "license": "MIT",
    "authors": [
        {
            "name": "Faheem Anis",
            "email": "faheem@cartzlink.com",
            "homepage": "https://faheemanis.rf.gd/",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.0",
        "bolt-php/contracts": ">=1.2.0"
    },
    "autoload": {
        "psr-4": {
            "framework\\validation\\": "src/",
            "framework\\validation\\tests\\": "tests/"
        }
